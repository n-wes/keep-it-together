# ===========================
# Unity .gitignore
# ===========================

# Unity generated folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/
[Aa]sset[Ss]tore[Tt]ools/

# Unity3D generated meta files (for asset databases)
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated project files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity Package Manager
/[Pp]ackages/com.unity.*/

# ===========================
# Build outputs
# ===========================
*.apk
*.aab
*.unitypackage
*.app
*.exe
*.dll
!Assets/Plugins/**/*.dll

# ===========================
# OS generated files
# ===========================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ===========================
# IDE / Editor folders
# ===========================
.vs/
.vscode/
.idea/
*.swp
*.swo
*~

# Rider
.idea/
*.sln.iml

# Visual Studio
ExportedObj/
*.svd
*.unityproj
*.user
*.tmp
*.pidb

# ===========================
# Crash reports
# ===========================
crashlytics-build.properties
sysinfo.txt
crash.dmp
*.stackdump

# ===========================
# ML-Agents
# ===========================
ml-agents/results/
*.onnx
*.nn

# ===========================
# Plastic SCM (ignore if not used)
# ===========================
*.private.0
*.private

# ===========================
# Gradle (Android builds)
# ===========================
.gradle/
local.properties
*.class
